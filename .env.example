# Notion — create an internal integration and share your database with it.
# https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional: property names if your Notion DB uses different labels (defaults match README).
# NOTION_PROP_TITLE=Name
# NOTION_PROP_SOURCE_URL=Source URL
# ...

# Optional: OpenAI for hybrid LLM extraction when coverage is low or "Use LLM" is checked.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
